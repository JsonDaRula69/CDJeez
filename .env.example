# StreamFLACr configuration
# Generated by `streamflacr setup`

# Soulseek credentials (required)
SLSK_USERNAME=your_soulseek_username
SLSK_PASSWORD=your_soulseek_password

# SoundCloud user URL (all playlists monitored automatically)
SOUNDCLOUD_USER_URL=https://soundcloud.com/your-username

# Poll interval in seconds (default: 300 = 5 min)
SOUNDCLOUD_POLL_INTERVAL=300

# Download directory (Serato Auto Import watches this folder)
DOWNLOAD_DIR=/Users/djtchill/Music/_Serato_/Auto Import

# Serato database directory
SERATO_DIR=/Users/djtchill/Music/_Serato_

# Search preferences
SEARCH_TIMEOUT=30
PREFER_FREE_SLOTS=1
MIN_FILESIZE_MB=5
